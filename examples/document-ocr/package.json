{
  "name": "document-ocr",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "docker compose up -d && tsx web/server.ts",
    "start:gpu": "docker compose -f compose.gpu.yml up -d && tsx web/server.ts",
    "ui": "tsx web/server.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "regen-samples": "python3 scripts/generate_samples.py"
  },
  "dependencies": {
    "@superlinked/sie-sdk": "^0.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2"
  }
}
